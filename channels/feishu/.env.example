# Feishu (飞书 / Lark): from Feishu Open Platform app credentials.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values.

# Required: from Feishu Open Platform → app credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional: port/host this channel listens on (default 8016 / 0.0.0.0)
# FEISHU_CHANNEL_PORT=8016
# FEISHU_CHANNEL_HOST=0.0.0.0

# Optional: Feishu API base (use https://open.larksuite.com for Lark)
# FEISHU_BASE_URL=https://open.feishu.cn
# FEISHU_EVENT_PATH=/feishu/events
