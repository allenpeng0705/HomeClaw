# Google Chat channel: credentials and server settings.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values.

# Optional: host/port this channel listens on (default 8010 / 0.0.0.0)
# GOOGLE_CHAT_HOST=0.0.0.0
# GOOGLE_CHAT_PORT=8010

# Optional: base URL for serving image files in cards (Google Chat requires HTTPS imageUrl). Set to a URL that serves files under your sandbox (e.g. core_public_url + /files/out or a CDN).
# GOOGLE_CHAT_IMAGE_BASE_URL=
