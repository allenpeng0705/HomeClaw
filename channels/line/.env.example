# LINE channel: LINE Messaging API credentials and optional settings.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values. Get tokens from LINE Developers Console.

# Required: from LINE Developers Console → Channel → Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Optional: base URL for outbound images (LINE requires HTTPS URLs). Set to a URL that serves image files (e.g. core_public_url + /files/out).
# LINE_IMAGE_BASE_URL=
