# Matrix channel: homeserver and bot account. Loaded from channels/matrix/.env.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values. Use a dedicated bot account (e.g. @bot:matrix.org).

# Required: Matrix homeserver URL and bot credentials
home_server=https://matrix.org
username=@your_bot:matrix.org
password=your_bot_password
