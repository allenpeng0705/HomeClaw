# Signal channel: bridge posts to this server; no bot token here. Server host/port only.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values if you need to override defaults.

# Optional: host/port this channel listens on (default 8011 / 0.0.0.0)
SIGNAL_CHANNEL_HOST=0.0.0.0
SIGNAL_CHANNEL_PORT=8011
