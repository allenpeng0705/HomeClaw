# Microsoft Teams (Bot Framework) channel: app credentials and server settings.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values. Create app at https://dev.botframework.com/.

# Required: Bot Framework app registration
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
# Or legacy names:
# MICROSOFT_APP_ID=
# MICROSOFT_APP_PASSWORD=

# Optional: host/port this channel listens on (default 8013 / 0.0.0.0)
# TEAMS_CHANNEL_HOST=0.0.0.0
# TEAMS_CHANNEL_PORT=8013
