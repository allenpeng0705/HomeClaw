# Tinode channel: optional env overrides. Host/port are in config.yml.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values if needed.

# Optional: set to 1 or true to process messages from the same account (e.g. mobile + channel)
# TINODE_ALLOW_SAME_USER=0
