# WebChat channel: browser UI over WebSocket. User identity and server settings.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values if you need to override defaults.

# Optional: user_id sent to Core for WebChat sessions (default webchat_user). Must exist in config/user.yml.
# WEBCHAT_USER_ID=webchat_user

# Optional: host/port this channel listens on (default 8014 / 0.0.0.0)
# WEBCHAT_HOST=0.0.0.0
# WEBCHAT_PORT=8014
