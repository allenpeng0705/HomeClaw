# WhatsApp Web channel: bridge or client posts to this server. Server host/port only.
# Core connection: use channels/.env (core_host, core_port, CORE_API_KEY).
# Copy to .env and set values if you need to override defaults.

# Optional: host/port this channel listens on (default 8010 / 0.0.0.0)
# WHATSAPPWEB_HOST=0.0.0.0
# WHATSAPPWEB_PORT=8010
