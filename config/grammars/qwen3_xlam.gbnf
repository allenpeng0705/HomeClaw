# Qwen3-4B xLAM/Codex tool-call grammar for llama.cpp (e.g. Manojb/Qwen3-4B-toolcalling-gguf-codex).
# Output: <tool_call>\n{"name": "function_name", "arguments": {...}}\n</tool_call>
# Use with: tools in prompt (no tools array), stop ["</tool_call>"], and a system prompt that mentions <tools></tools> and <tool_call></tool_call>. See llm.yml llama_cpp.tool_selection.qwen3_xlam_style.

root        ::= tool_call
tool_call   ::= "<tool_call>\n" json_object "\n</tool_call>"

json_object ::= "{" ws (kv_pair ("," ws kv_pair)*)? ws "}"
kv_pair     ::= string ws ":" ws value
value       ::= string | number | json_object | array | "true" | "false" | "null"
string      ::= "\"" ([^"\\] | "\\" ["\\/bfnrt] | "\\u" [0-9a-fA-F]{4})* "\""
number      ::= "-"? ([0-9] | [1-9] [0-9]*) ("." [0-9]+)? ([eE] [+-]? [0-9]+)?
array       ::= "[" ws (value ("," ws value)*)? ws "]"
ws          ::= [ \t\n\r]*
